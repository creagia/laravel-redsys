parameters:
    level: 7
    paths:
        - src
        - config
        - database
    configDirectories:
        - config
    tmpDir: build/phpstan
    checkOctaneCompatibility: true
    checkModelProperties: true
    ignoreErrors:
        - identifier: argument.type
          path: src/Controllers/*
        - identifier: trait.unused
          path: src/Concerns/*
